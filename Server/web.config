<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <security>
      <requestFiltering>
        <!-- Allow large file uploads up to 500MB -->
        <requestLimits maxAllowedContentLength="524288000" />
      </requestFiltering>
    </security>

    <!--
      CRITICAL for SignalR: IIS requires WebSocket Protocol to be explicitly enabled.
      Without this, SignalR cannot upgrade the HTTP connection to a WebSocket,
      causing /batchlockhub connections to fail and the Monitor UI to break.
      Pre-requisite: Enable "WebSocket Protocol" in Windows Features under IIS.
    -->
    <webSocket enabled="true" />

    <!--
      applicationInitialization: IIS will automatically call /health after a worker
      process (re)start. This "pre-warms" the app so background services are running
      before the first real request arrives — and counts as activity to prevent
      immediate idle timeout (WAS Event 5186).
    -->
    <applicationInitialization doAppInitAfterRestart="true" skipManagedModules="false">
      <add initializationPage="/health" />
    </applicationInitialization>

    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>

    <!--
      stdoutLogEnabled="true" and a log file path are critical for diagnosing
      crashes in production IIS. Enable these if background services stop unexpectedly.
      Set to false when not actively debugging to avoid disk fill.
    -->
    <aspNetCore processPath="dotnet"
                arguments=".\Server.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess">
      <environmentVariables>
        <!-- Override in production deployment as needed -->
         <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Development" /> 
      </environmentVariables>
    </aspNetCore>

  </system.webServer>
</configuration>
